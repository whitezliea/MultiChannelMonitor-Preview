<UserControl x:Class="Presentation.Wpf.Views.AlarmCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="IsReadOnly" Value="True" />
        </Style>
        <DataTemplate x:Key="TwoDigitTimePartTemplate">
            <TextBlock Text="{Binding StringFormat={}{0:00}}" />
        </DataTemplate>
    </UserControl.Resources>
    <Border Style="{StaticResource PanelBorderStyle}">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <WrapPanel Margin="0,0,0,8">
                    <Button Content="Current" MinWidth="82" Margin="0,0,8,0" Command="{Binding ShowCurrentCommand}" />
                    <Button Content="Recent" MinWidth="82" Margin="0,0,8,0" Command="{Binding ShowRecentCommand}" />
                    <TextBlock Text="Start (local)" VerticalAlignment="Center" Margin="8,0,6,0" />
                    <DatePicker SelectedDate="{Binding StartDateLocal, Mode=TwoWay}"
                                SelectedDateFormat="Short"
                                Width="125"
                                Margin="0,0,4,0" />
                    <ComboBox ItemsSource="{Binding AvailableHours}"
                              SelectedItem="{Binding StartHour, Mode=TwoWay}"
                              ItemTemplate="{StaticResource TwoDigitTimePartTemplate}"
                              Width="48"
                              Margin="0,0,2,0" />
                    <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,2,0" />
                    <ComboBox ItemsSource="{Binding AvailableMinutes}"
                              SelectedItem="{Binding StartMinute, Mode=TwoWay}"
                              ItemTemplate="{StaticResource TwoDigitTimePartTemplate}"
                              Width="48"
                              Margin="0,0,8,0" />
                    <TextBlock Text="End (local)" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <DatePicker SelectedDate="{Binding EndDateLocal, Mode=TwoWay}"
                                SelectedDateFormat="Short"
                                Width="125"
                                Margin="0,0,4,0" />
                    <ComboBox ItemsSource="{Binding AvailableHours}"
                              SelectedItem="{Binding EndHour, Mode=TwoWay}"
                              ItemTemplate="{StaticResource TwoDigitTimePartTemplate}"
                              Width="48"
                              Margin="0,0,2,0" />
                    <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,2,0" />
                    <ComboBox ItemsSource="{Binding AvailableMinutes}"
                              SelectedItem="{Binding EndMinute, Mode=TwoWay}"
                              ItemTemplate="{StaticResource TwoDigitTimePartTemplate}"
                              Width="48"
                              Margin="0,0,8,0" />
                    <TextBlock Text="Tag" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Text="{Binding TagIdFilter, UpdateSourceTrigger=PropertyChanged}" Width="130" Margin="0,0,8,0" />
                    <TextBlock Text="Level" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox ItemsSource="{Binding AvailableLevels}" SelectedItem="{Binding SelectedLevel}" Width="90" Margin="0,0,8,0" />
                    <TextBlock Text="State" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox ItemsSource="{Binding AvailableStates}" SelectedItem="{Binding SelectedState}" Width="110" Margin="0,0,8,0" />
                    <Button Content="Query History" MinWidth="105" Margin="0,0,8,0" Command="{Binding QueryHistoryCommand}" />
                    <Button Content="Cancel" MinWidth="70" Command="{Binding CancelQueryCommand}" />
                </WrapPanel>
                <WrapPanel>
                    <Button Content="Previous" MinWidth="82" Margin="0,0,8,0" Command="{Binding PreviousPageCommand}" />
                    <Button Content="Next" MinWidth="82" Margin="0,0,12,0" Command="{Binding NextPageCommand}" />
                    <TextBlock Text="{Binding SelectedFilterText}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0" />
                    <TextBlock Text="{Binding QueryStatus}" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                </WrapPanel>
            </StackPanel>

            <DataGrid ItemsSource="{Binding AlarmEvents}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="TagId" Binding="{Binding TagId}" Width="*" />
                    <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="85" />
                    <DataGridTextColumn Header="Type" Binding="{Binding AlarmType}" Width="105" />
                    <DataGridTextColumn Header="State" Binding="{Binding State}" Width="105" />
                    <DataGridTextColumn Header="Value" Binding="{Binding TriggerValue, StringFormat=0.###}" Width="85" />
                    <DataGridTextColumn Header="Trigger (Local)" Binding="{Binding TriggerTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="150" />
                    <DataGridTextColumn Header="Updated" Binding="{Binding LastUpdatedTime, StringFormat=HH:mm:ss}" Width="85" />
                    <DataGridTextColumn Header="Ack" Binding="{Binding AcknowledgeTime, StringFormat=HH:mm:ss}" Width="75" />
                    <DataGridTextColumn Header="Recover" Binding="{Binding RecoverTime, StringFormat=HH:mm:ss}" Width="75" />
                    <DataGridTextColumn Header="Close Reason" Binding="{Binding CloseReason}" Width="140" />
                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="2*" />
                    <DataGridTemplateColumn Header="Action" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Ack"
                                        IsEnabled="{Binding CanAcknowledge}"
                                        Command="{Binding DataContext.AcknowledgeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
