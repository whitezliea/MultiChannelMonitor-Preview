<UserControl x:Class="Presentation.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:measurement="clr-namespace:Application.DTOs.MeasurementMap;assembly=Application"
             xmlns:scottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF">
    <UserControl.Resources>
        <Style x:Key="MatrixQualityBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#EEF2F6" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="9,3" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding MatrixQualityState}" Value="{x:Static measurement:MatrixQualityState.Good}">
                    <Setter Property="Background" Value="#E8F7EE" />
                    <Setter Property="BorderBrush" Value="#78C793" />
                </DataTrigger>
                <DataTrigger Binding="{Binding MatrixQualityState}" Value="{x:Static measurement:MatrixQualityState.Attention}">
                    <Setter Property="Background" Value="#FFF7DE" />
                    <Setter Property="BorderBrush" Value="#E2B93B" />
                </DataTrigger>
                <DataTrigger Binding="{Binding MatrixQualityState}" Value="{x:Static measurement:MatrixQualityState.Warning}">
                    <Setter Property="Background" Value="#FFF0E1" />
                    <Setter Property="BorderBrush" Value="#E68A2E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding MatrixQualityState}" Value="{x:Static measurement:MatrixQualityState.Alarm}">
                    <Setter Property="Background" Value="#FDECEC" />
                    <Setter Property="BorderBrush" Value="{StaticResource AlarmBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MatrixQualityTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding MatrixQualityState}" Value="{x:Static measurement:MatrixQualityState.Good}">
                    <Setter Property="Foreground" Value="#217A43" />
                </DataTrigger>
                <DataTrigger Binding="{Binding MatrixQualityState}" Value="{x:Static measurement:MatrixQualityState.Attention}">
                    <Setter Property="Foreground" Value="#8A6412" />
                </DataTrigger>
                <DataTrigger Binding="{Binding MatrixQualityState}" Value="{x:Static measurement:MatrixQualityState.Warning}">
                    <Setter Property="Foreground" Value="#A65312" />
                </DataTrigger>
                <DataTrigger Binding="{Binding MatrixQualityState}" Value="{x:Static measurement:MatrixQualityState.Alarm}">
                    <Setter Property="Foreground" Value="{StaticResource AlarmBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MatrixSummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MatrixSummaryValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ItemsControl Grid.Row="0" ItemsSource="{Binding Metrics}" Margin="0,0,0,14">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Text="{Binding Value}" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Key Measurements" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <DataGrid Grid.Row="1" ItemsSource="{Binding KeyMeasurements}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*" />
                            <DataGridTextColumn Header="Value" Binding="{Binding DisplayValue}" Width="90" />
                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="70" />
                            <DataGridTextColumn Header="Quality" Binding="{Binding Quality}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Recent Trend - MEAS.TEMP.CH01" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <Grid Grid.Row="1" MinHeight="120">
                        <scottPlot:WpfPlot x:Name="RecentTrendPlot" />
                        <Border Background="#DDF3F6F8"
                                CornerRadius="4"
                                IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTrendPreview}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Waiting for recent trend samples."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <TextBlock Grid.Row="2"
                               Text="{Binding TrendWindowText}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               Margin="0,6,0,0" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Active Alarms" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ListBox Grid.Row="1" ItemsSource="{Binding ActiveAlarms}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,3,0,8">
                                    <TextBlock Text="{Binding TagId}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Message}" Foreground="{StaticResource AlarmBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" MinHeight="170">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Measurement Map Preview"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="1" Style="{StaticResource MatrixQualityBadgeStyle}">
                            <TextBlock Text="{Binding MatrixQualityText}" Style="{StaticResource MatrixQualityTextStyle}" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" MinWidth="155" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="2*" MinWidth="125" />
                        </Grid.ColumnDefinitions>

                        <Border Background="#EEF2F6"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="4">
                            <Viewbox Stretch="Uniform" StretchDirection="Both">
                                <Grid Width="208" Height="208">
                                    <ItemsControl ItemsSource="{Binding MatrixPreviewCells}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasMatrixPreview}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="{Binding DataContext.MatrixPreviewColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0.35" Background="{Binding Background}">
                                                    <Border x:Name="CellBorder"
                                                            BorderBrush="#55FFFFFF"
                                                            BorderThickness="0.4" />
                                                    <Border x:Name="AlertBadge"
                                                            Width="9"
                                                            Height="9"
                                                            Margin="0.5"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Background="#D28A6412"
                                                            CornerRadius="4.5"
                                                            Visibility="Collapsed">
                                                        <TextBlock Text="X"
                                                                   Foreground="White"
                                                                   FontSize="6"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsAbnormal}" Value="True">
                                                        <Setter TargetName="AlertBadge" Property="Visibility" Value="Visible" />
                                                        <Setter TargetName="CellBorder" Property="BorderBrush" Value="White" />
                                                        <Setter TargetName="CellBorder" Property="BorderThickness" Value="1" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Severity}" Value="{x:Static measurement:MatrixSeverity.Alarm}">
                                                        <Setter TargetName="AlertBadge" Property="Background" Value="{StaticResource AlarmBrush}" />
                                                        <Setter TargetName="CellBorder" Property="BorderBrush" Value="#FFFFE0" />
                                                        <Setter TargetName="CellBorder" Property="BorderThickness" Value="1.4" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="No Data"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasMatrixPreview}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Viewbox>
                        </Border>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Max" Style="{StaticResource MatrixSummaryLabelStyle}" Margin="0,0,8,4" />
                            <TextBlock Grid.Column="1" Text="{Binding MatrixMaximumText}" Style="{StaticResource MatrixSummaryValueStyle}" Margin="0,0,0,4" />

                            <TextBlock Grid.Row="1" Text="Avg" Style="{StaticResource MatrixSummaryLabelStyle}" Margin="0,0,8,4" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MatrixAverageText}" Style="{StaticResource MatrixSummaryValueStyle}" Margin="0,0,0,4" />

                            <TextBlock Grid.Row="2" Text="Uniformity" Style="{StaticResource MatrixSummaryLabelStyle}" Margin="0,0,8,4" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MatrixUniformityText}" Style="{StaticResource MatrixSummaryValueStyle}" Margin="0,0,0,4" />

                            <TextBlock Grid.Row="3" Text="Abnormal" Style="{StaticResource MatrixSummaryLabelStyle}" Margin="0,0,8,6" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MatrixAbnormalCountText}" Style="{StaticResource MatrixSummaryValueStyle}" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="4" Text="Main Point" Style="{StaticResource MatrixSummaryLabelStyle}" Margin="0,0,8,4" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Text="{Binding MainAbnormalPointText}"
                                       Style="{StaticResource MatrixSummaryValueStyle}"
                                       Margin="0,0,0,4"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding MainAbnormalTypeText}" />

                            <Button Grid.Row="6"
                                    Grid.ColumnSpan="2"
                                    Command="{Binding OpenMeasurementMapCommand}"
                                    Content="Open Map >"
                                    MinHeight="26"
                                    Padding="8,2"
                                    HorizontalAlignment="Right"
                                    Background="#EFF6FF"
                                    BorderBrush="#BFDBFE"
                                    Foreground="{StaticResource AccentBrush}"
                                    FontWeight="SemiBold" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
