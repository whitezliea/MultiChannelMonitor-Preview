<UserControl x:Class="Presentation.Wpf.Views.MeasurementMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:measurement="clr-namespace:Application.DTOs.MeasurementMap;assembly=Application">
    <UserControl.Resources>
        <Style x:Key="HeatmapCellButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="280" />
            <RowDefinition Height="170" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,12" Padding="12,9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="Matrix Type" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding MatrixType}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,18,0" />

                    <TextBlock Text="Scale" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox ItemsSource="{Binding AvailableScaleModes}"
                              SelectedItem="{Binding SelectedScaleMode}"
                              Width="165"
                              Margin="0,0,14,0" />

                    <TextBlock Text="Palette" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox ItemsSource="{Binding AvailablePalettes}"
                              SelectedItem="{Binding SelectedPalette}"
                              Width="130"
                              Margin="0,0,14,0" />

                    <CheckBox Content="Show Values"
                              IsChecked="{Binding ShowValues}"
                              VerticalAlignment="Center"
                              Margin="0,0,14,0" />
                    <CheckBox Content="Freeze"
                              IsChecked="{Binding IsFrozen}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0" />
                    <TextBlock Text="{Binding FreezeStatusText}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="{Binding DataStatusText, StringFormat=Data: {0}}"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock VerticalAlignment="Center" Margin="14,0,0,0" Foreground="{StaticResource TextMutedBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Text" Value="Fixed range: 0 - 2000 lux" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedScaleMode}"
                                                 Value="{x:Static measurement:MatrixScaleMode.FixedEngineeringRange}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </WrapPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding MatrixSizeText}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TimestampText}" HorizontalAlignment="Right" Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="270" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Measurement Heatmap" Style="{StaticResource SectionTitleStyle}" />

                    <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly">
                        <Grid Width="560" Height="560">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding ColumnHeaders}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="{Binding DataContext.Columns, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" Foreground="{StaticResource TextMutedBrush}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl Grid.Row="1" Grid.Column="0" ItemsSource="{Binding RowHeaders}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="{Binding DataContext.Rows, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Columns="1" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" Foreground="{StaticResource TextMutedBrush}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Grid.Row="1" Grid.Column="1" Background="#111827" BorderBrush="#3A4654" BorderThickness="1">
                                <ItemsControl ItemsSource="{Binding Cells}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="{Binding DataContext.Columns, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button x:Name="CellButton"
                                                    Style="{StaticResource HeatmapCellButtonStyle}"
                                                    Command="{Binding DataContext.SelectPointCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Border x:Name="CellBorder"
                                                        Background="{Binding Background}"
                                                        BorderBrush="#70FFFFFF"
                                                        BorderThickness="0.5"
                                                        Margin="0.5"
                                                        ToolTip="{Binding TooltipText}">
                                                    <Grid>
                                                        <Border x:Name="ValueBackground"
                                                                Background="#78000000"
                                                                CornerRadius="2"
                                                                Padding="2,0"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Visibility="Collapsed">
                                                            <TextBlock Text="{Binding DisplayValue}"
                                                                       Foreground="White"
                                                                       FontSize="9"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                        <Border x:Name="AlertMarker"
                                                                Background="#D92D20"
                                                                CornerRadius="6"
                                                                Width="12"
                                                                Height="12"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0.5"
                                                                Visibility="Collapsed">
                                                            <TextBlock Text="X" Foreground="White" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Button>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsValueVisible}" Value="True">
                                                    <Setter TargetName="ValueBackground" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <Trigger SourceName="CellButton" Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ValueBackground" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="CellBorder" Property="BorderBrush" Value="#F2F4F7" />
                                                    <Setter TargetName="CellBorder" Property="BorderThickness" Value="1.5" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsAbnormal}" Value="True">
                                                    <Setter TargetName="AlertMarker" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="CellBorder" Property="BorderBrush" Value="#F79009" />
                                                    <Setter TargetName="CellBorder" Property="BorderThickness" Value="1.5" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="{x:Static measurement:MatrixSeverity.Alarm}">
                                                    <Setter TargetName="CellBorder" Property="BorderBrush" Value="#D92D20" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter TargetName="CellBorder" Property="BorderBrush" Value="White" />
                                                    <Setter TargetName="CellBorder" Property="BorderThickness" Value="2.5" />
                                                    <Setter TargetName="ValueBackground" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Grid>
                    </Viewbox>

                    <Grid Grid.Row="2" Margin="38,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding LegendMinimumText}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Border Grid.Column="1" Height="12" CornerRadius="3">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#14244E" Offset="0" />
                                    <GradientStop Color="#0082B4" Offset="0.25" />
                                    <GradientStop Color="#28AA5A" Offset="0.5" />
                                    <GradientStop Color="#F5BE3C" Offset="0.75" />
                                    <GradientStop Color="#D2372D" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Grid.Column="2" Text="{Binding LegendMaximumText}" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </Grid>

                    <TextBlock Text="Waiting for matrix frame..."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasData}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Statistics" Style="{StaticResource SectionTitleStyle}" />

                        <Border CornerRadius="4" Padding="8,5" Margin="0,0,0,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#EAF7EE" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding QualityText}" Value="Attention">
                                            <Setter Property="Background" Value="#FFF4CC" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding QualityText}" Value="Warning">
                                            <Setter Property="Background" Value="#FFE8C2" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding QualityText}" Value="Alarm">
                                            <Setter Property="Background" Value="#FEE4E2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DockPanel>
                                <TextBlock Text="Quality" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding QualityText}" DockPanel.Dock="Right" FontWeight="Bold" HorizontalAlignment="Right" />
                            </DockPanel>
                        </Border>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Max" /><TextBlock Grid.Column="1" Text="{Binding MaximumText}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1" Text="Min" /><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MinimumText}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="2" Text="Average" /><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AverageText}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="3" Text="StdDev" /><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding StdDevText}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="4" Text="Uniformity" /><TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding UniformityText}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="5" Text="Valid" /><TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ValidCountText}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="6" Text="Invalid" /><TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding InvalidCountText}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="7" Text="Abnormal" /><TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding AbnormalCountText}" FontWeight="SemiBold" />
                        </Grid>

                        <Separator Margin="0,2,0,12" />
                        <TextBlock Text="Selected Point" Style="{StaticResource SectionTitleStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Position" Margin="0,0,10,4" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedPoint.CoordinateText, TargetNullValue=--}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1" Text="Value" Margin="0,0,10,4" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPoint.ValueWithUnit, TargetNullValue=--}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="2" Text="Type" Margin="0,0,10,0" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedPoint.AbnormalType, TargetNullValue=Normal}" FontWeight="SemiBold" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Abnormal Points" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,6" />
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding AbnormalPoints}"
                          SelectedItem="{Binding SelectedAbnormalPoint, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Row" Binding="{Binding RowText}" Width="55" />
                        <DataGridTextColumn Header="Col" Binding="{Binding ColumnText}" Width="55" />
                        <DataGridTextColumn Header="Value" Binding="{Binding ValueText}" Width="100" />
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="150" />
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90" />
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
