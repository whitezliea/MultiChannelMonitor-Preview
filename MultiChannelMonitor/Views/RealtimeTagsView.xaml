<UserControl x:Class="Presentation.Wpf.Views.RealtimeTagsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Category" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Width="130" Margin="0,0,12,0" />
                <TextBlock Text="Quality" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox ItemsSource="{Binding Qualities}" SelectedItem="{Binding SelectedQuality}" Width="130" Margin="0,0,12,0" />
                <TextBlock Text="Alarm" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox ItemsSource="{Binding AlarmStates}" SelectedItem="{Binding SelectedAlarmState}" Width="140" Margin="0,0,12,0" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="220" Margin="0,0,12,0" />
                <Button Content="Clear" Command="{Binding ClearFilterCommand}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}">
            <DataGrid ItemsSource="{Binding Tags}" SelectedItem="{Binding SelectedTag}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="TagId" Binding="{Binding TagId}" Width="*" />
                    <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*" />
                    <DataGridTextColumn Header="Value" Binding="{Binding DisplayValue}" Width="100" />
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="70" />
                    <DataGridTextColumn Header="Quality" Binding="{Binding Quality}" Width="110" />
                    <DataGridTextColumn Header="Alarm" Binding="{Binding AlarmState}" Width="130" />
                    <DataGridTextColumn Header="Data" Binding="{Binding DataStatus}" Width="90" />
                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Selected Tag Detail" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding SelectedTag.TagId}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedTag.DisplayName}" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="{Binding SelectedTag.AlarmState, StringFormat=Alarm: {0}}" Foreground="{StaticResource AlarmBrush}" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Open Trend"
                        Command="{Binding OpenTrendCommand}"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
