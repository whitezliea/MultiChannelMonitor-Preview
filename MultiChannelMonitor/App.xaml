<Application x:Class="Presentation.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Presentation.Wpf.Views"
             xmlns:viewModels="clr-namespace:Presentation.Wpf.ViewModels"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F3F6F8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D8E0EA" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2933" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#667085" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AlarmBrush" Color="#B42318" />

        <Style TargetType="Border" x:Key="PanelBorderStyle">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style TargetType="TextBlock" x:Key="PageTitleStyle">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
        </Style>

        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:RealtimeTagsViewModel}">
            <views:RealtimeTagsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:TrendViewModel}">
            <views:TrendView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AlarmCenterViewModel}">
            <views:AlarmCenterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:HistoryViewModel}">
            <views:HistoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:MeasurementMapViewModel}">
            <views:MeasurementMapView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:LogsSettingsViewModel}">
            <views:LogsSettingsView />
        </DataTemplate>
    </Application.Resources>
</Application>
