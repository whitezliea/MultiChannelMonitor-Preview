<UserControl x:Class="Presentation.Wpf.Controls.MetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource PanelBorderStyle}">
        <StackPanel>
            <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextMutedBrush}" />
            <TextBlock Text="{Binding Value}" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource TextMutedBrush}" />
        </StackPanel>
    </Border>
</UserControl>
